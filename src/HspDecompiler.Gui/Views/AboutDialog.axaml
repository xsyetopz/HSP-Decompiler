<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HspDecompiler.Gui.ViewModels"
        x:Class="HspDecompiler.Gui.Views.AboutDialog"
        x:DataType="vm:AboutViewModel"
        Title=""
        Width="300" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Design.DataContext>
        <vm:AboutViewModel />
    </Design.DataContext>
    <StackPanel Margin="20" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="{Binding Version, StringFormat='Version {0}'}" HorizontalAlignment="Center" />
        <TextBlock Text="{Binding Copyright}" HorizontalAlignment="Center" TextWrapping="Wrap" />
        <Button Content="OK" HorizontalAlignment="Center" Click="OnOkClick" Margin="0,8,0,0" />
    </StackPanel>
</Window>
